# coding-agent 环境变量样例
# 复制为 .env 后填入真实值（.env 已在 .gitignore 中）
# 实际生效优先级：shell env > .env > 默认值

# 必填：OpenAI 兼容服务的 API key
# OPENAI_API_KEY=sk-your-key-here

# 可选：自定义 base URL（用于 DeepSeek / 其它 OpenAI 兼容服务）
# OPEN_BASE_URL=https://api.deepseek.com/v1

# 可选：默认模型（留空走 gpt-4o-mini）
# OPENAI_MODEL=gpt-4o-mini

# 可选：单次响应最大 token（0 表示不显式传给模型）
# CODING_AGENT_MAX_TOKENS=0

# 可选：agent loop 最大轮数（默认 100）
# CODING_AGENT_MAX_TURNS=100

# 可选：系统提示词（一般留空，让程序按工具自动生成）
# CODING_AGENT_SYSTEM_PROMPT=

# 可选：采样温度（0 表示不传）
# CODING_AGENT_TEMPERATURE=0.0

# ---------- Context Compaction ----------
# 上下文窗口 token 上限（<=0 表示关闭自动 compaction）
# CODING_AGENT_CONTEXT_WINDOW=0

# 软阈值：仅提示临近上下文上限，不触发压缩
# CODING_AGENT_SOFT_COMPACT_RATIO=0.50

# 触发阈值：达到后触发摘要压缩
# CODING_AGENT_COMPACT_RATIO=0.80

# 强制阈值：达到后强制压缩（会跳过低价值折叠判断）
# CODING_AGENT_COMPACT_FORCE_RATIO=0.90

# 压缩时至少保留的最近消息条数
# CODING_AGENT_RECENT_KEEP=3

# 消息数超过该值时先做 snip_compact（<=0 关闭）
# CODING_AGENT_MAX_MESSAGES_SNIP=80

# 压缩归档根目录（默认：~/.coding-agent/archives）
# 程序会自动按“项目名-路径哈希”分桶，并执行 14 天 + 1GB/项目 清理。
# CODING_AGENT_ARCHIVE_DIR=
