# coding-agent 环境变量样例
# 复制为 .env 后填入真实值（.env 已在 .gitignore 中）
# 实际生效优先级：shell env > .env > 默认值

# 必填：OpenAI 兼容服务的 API key
OPENAI_API_KEY=sk-your-key-here

# 可选：自定义 base URL（用于 DeepSeek / 其它 OpenAI 兼容服务）
# OPEN_BASE_URL=https://api.deepseek.com/v1

# 可选：默认模型（留空走 gpt-4o-mini）
# OPENAI_MODEL=gpt-4o-mini
